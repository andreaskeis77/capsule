include README.md
include requirements.txt
include pytest.ini
include .env.example
recursive-include docs *.md
recursive-include ontology *.json *.yaml *.yml *.md
recursive-include templates *.html *.jinja2 *.txt
recursive-include src *.py
recursive-include tools *.py
global-exclude __pycache__ *.pyc *.pyo
prune .git
prune .venv
prune 04_user_data
