# Wardrobe Studio configuration (copy to .env)
# IMPORTANT: .env is intentionally NOT versioned. Keep secrets out of git.

# Environment
WARDROBE_ENV=dev
WARDROBE_DEBUG=0

# Server
WARDROBE_HOST=0.0.0.0
WARDROBE_PORT=5002

# Logging
WARDROBE_LOG_LEVEL=INFO
# WARDROBE_LOG_DIR=logs
# WARDROBE_LOG_FILE=logs/wardrobe.log

# Security
# Set this to a strong random value and also configure it in the Custom GPT Action header (X-API-Key).
WARDROBE_API_KEY=CHANGE_ME
WARDROBE_ALLOW_LOCAL_NOAUTH=0

# Mount Flask dashboard on "/" (1=on, 0=off). Useful to disable in tests.
WARDROBE_MOUNT_FLASK=1

# Storage (optional overrides; defaults apply if unset)
# WARDROBE_DB_PATH=03_database/wardrobe.db
# WARDROBE_IMG_DIR=02_wardrobe_images
# Where deleted image folders are moved before cleanup (keeps deletes reversible if DB commit fails)
# WARDROBE_TRASH_DIR=04_user_data/trash_images

# Images
WARDROBE_MAX_IMAGE_MB=8
WARDROBE_IMAGE_MAX_DIM=1600
WARDROBE_IMAGE_JPEG_QUALITY=85
WARDROBE_STORE_ORIGINAL=0

# Ontology validation
# off|soft|strict
WARDROBE_ONTOLOGY_MODE=soft
WARDROBE_ONTOLOGY_ALLOW_LEGACY=1
WARDROBE_ONTOLOGY_FUZZY_THRESHOLD=0.92
WARDROBE_ONTOLOGY_SUGGEST_THRESHOLD=0.78
WARDROBE_ONTOLOGY_DIR=ontology
WARDROBE_ONTOLOGY_OVERRIDES_FILE=ontology/ontology_overrides.yaml
WARDROBE_ONTOLOGY_COLOR_LEXICON_FILE=ontology/color_lexicon.yaml
WARDROBE_ONTOLOGY_TOLERANT_FIELDS=color_primary